# Rename this file to ".env" and fill in your real values.
# NEVER commit the real .env file to GitHub.

PORT=5000
MONGO_URI=your_mongodb_atlas_connection_string_here
JWT_SECRET=make_this_a_long_random_string
CLIENT_URL=http://localhost:5173

# Phase 4 — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Phase 5 — URL of the Python ML service (see /ml-service)
ML_SERVICE_URL=http://localhost:8000

# Phase 9 — SMTP credentials for sending emails (e.g. Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
